#!/usr/bin/env bash
# remarklaude — an e-ink-friendly REPL around the Claude Code CLI.
#
# Runs on the host machine (the one with an authenticated `claude` CLI).
# Meant to be launched over SSH from a reMarkable terminal (fingerterm,
# ReTerm, ...). Each line of input triggers exactly one `claude -p` call
# and one clean block of plain-text output — no live-redrawing TUI, no
# spinners, nothing that would ghost/flicker on e-ink.
set -euo pipefail

CLAUDE_BIN="${CLAUDE_BIN:-claude}"
WORKDIR="${REMARKLAUDE_DIR:-$HOME}"
MODEL="${REMARKLAUDE_MODEL:-}"

cd "$WORKDIR"

new_session_id() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    od -An -N16 -tx1 /dev/urandom | tr -d ' \n' \
      | sed -E 's/^(.{8})(.{4})(.{4})(.{4})(.{12})$/\1-\2-\3-\4-\5/'
  fi
}

print_help() {
  cat <<'EOF'

remarklaude commands:
  /new    start a fresh conversation
  /help   show this message
  /exit   quit (also: /quit, Ctrl-D)

Anything else is sent to Claude as a message.
EOF
}

SID="$(new_session_id)"
FIRST=1

echo "remarklaude — Claude Code over e-ink"
echo "Type a message and press Enter. /help for commands."

while true; do
  printf '\nyou> '
  if ! IFS= read -r input; then
    echo
    break
  fi

  case "$input" in
    '')
      continue
      ;;
    /exit|/quit)
      break
      ;;
    /help)
      print_help
      continue
      ;;
    /new)
      SID="$(new_session_id)"
      FIRST=1
      echo "(started a new conversation)"
      continue
      ;;
  esac

  args=(-p --ax-screen-reader --output-format text)
  if [[ "$FIRST" -eq 1 ]]; then
    args+=(--session-id "$SID")
    FIRST=0
  else
    args+=(--resume "$SID")
  fi
  if [[ -n "$MODEL" ]]; then
    args+=(--model "$MODEL")
  fi

  printf '\nclaude> \n'
  "$CLAUDE_BIN" "${args[@]}" "$input" < /dev/null
  echo
done

echo "goodbye"
